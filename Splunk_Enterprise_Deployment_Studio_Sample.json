    "customerShortName": "acme",
    "environment": "prod",
    "platform": "splunk_enterprise",
    "topologyPattern": "distributed_clustered",
    "splunkVersion": "9.4.x",
    "description": "Enterprise-ready Splunk planning workbook with site-aware architecture, onboarding matrix, deployment guidance, validation, and troubleshooting."
