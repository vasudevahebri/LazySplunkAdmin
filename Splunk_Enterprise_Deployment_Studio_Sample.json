  "globals": {
    "sshUser": "splunkadm",
    "sshPassword": "DemoSSH!234",
    "splunkAdminUser": "admin",
    "splunkAdminPassword": "DemoSplunk!234",
    "runtimeUser": "splunk",
    "packageDir": "/opt",
    "enterprisePackage": "splunk-9.x-linux-x86_64.tgz",
    "forwarderPackage": "splunkforwarder-9.x-linux-x86_64.tgz",
    "enterpriseHome": "/opt/splunk",
    "forwarderHome": "/opt/splunkforwarder",
    "receiverPort": "9997",
    "deploymentPollInterval": "60",
    "usePublicIpForSsh": true,
    "usePrivateIpForSplunk": true,
    "enableBootStart": true,
    "hecPort": "8088"
  },
  "cluster": {
    "indexerClustering": true,
    "searchHeadClustering": true,
    "multisite": true,
    "availableSites": "site1,site2",
    "siteReplicationFactor": "origin:1,total:2",
    "siteSearchFactor": "origin:1,total:2",
    "indexerReplicationFactor": "3",
    "indexerSearchFactor": "2",
    "indexerClusterSecret": "DemoIdxc!234",
    "indexerClusterLabel": "prod_idxc",
    "indexerReplicationPort": "9887",
    "searchHeadClusterSecret": "DemoShc!234",
    "searchHeadClusterLabel": "prod_shc",
    "searchHeadReplicationFactor": "3",
    "searchHeadReplicationPort": "8181",
    "kvstoreReplicationPort": "8191"
  },
  "security": {
    "tlsEnabled": true,
    "vpnOrPrivateAccess": true,
    "hecEnabled": true,
    "firewallReviewed": true,
    "passwordRotation": true,
    "notes": "Restrict Splunk Web and management ports to admin networks only."
