  "dataSources": [
    {
      "id": "d01",
      "name": "AD Servers - Windows Security",
      "category": "security",
      "method": "windows_event",
      "sourceHost": "ad01, ad02",
      "hostGroup": "windows-ad",
      "inputName": "Security",
      "sourceLocation": "Windows Event Log: Security",
      "collectionTier": "universal_forwarder",
      "targetIndex": "winevent",
      "sourcetype": "WinEventLog:Security",
      "appName": "Splunk_TA_windows",
      "sourceCount": "2",
      "avgGBPerSourcePerDay": "47.5",
      "estGBPerDay": "95",
      "retentionDays": "180",
      "searchProfile": "high",
      "notes": "One AD server can produce Security, System, DNS Server, Directory Service, and app logs. Use separate rows per input."
    },
    {
      "id": "d02",
      "name": "AD Servers - DNS Server",
      "category": "application",
      "method": "windows_event",
      "sourceHost": "ad01, ad02",
      "hostGroup": "windows-ad",
      "inputName": "DNS Server",
      "sourceLocation": "Windows Event Log: DNS Server",
      "collectionTier": "universal_forwarder",
      "targetIndex": "infra_dns",
      "sourcetype": "WinEventLog:DNS Server",
      "appName": "Splunk_TA_windows",
      "sourceCount": "2",
      "avgGBPerSourcePerDay": "9",
      "estGBPerDay": "18",
      "retentionDays": "180",
      "searchProfile": "medium",
      "notes": "Clone this row when the same AD hosts also send DNS Analytical or custom DNS text logs."
    },
    {
      "id": "d03",
      "name": "AD Servers - Directory Service",
      "category": "security",
      "method": "windows_event",
      "sourceHost": "ad01, ad02",
      "hostGroup": "windows-ad",
      "inputName": "Directory Service",
      "sourceLocation": "Windows Event Log: Directory Service",
      "collectionTier": "universal_forwarder",
      "targetIndex": "winevent",
      "sourcetype": "WinEventLog:Directory Service",
      "appName": "Splunk_TA_windows",
      "sourceCount": "2",
      "avgGBPerSourcePerDay": "6",
      "estGBPerDay": "12",
      "retentionDays": "180",
      "searchProfile": "medium",
      "notes": "Useful for domain controller and identity monitoring."
    },
    {
      "id": "d04",
      "name": "Linux App Tier - OS Logs",
      "category": "os",
      "method": "linux_ta",
      "sourceHost": "app01, app02, app03",
      "hostGroup": "linux-app",
      "inputName": "/var/log/messages + secure",
      "sourceLocation": "/var/log/messages ; /var/log/secure",
      "collectionTier": "universal_forwarder",
      "targetIndex": "os",
      "sourcetype": "linux_secure",
      "appName": "Splunk_Add-on_for_Unix_and_Linux",
      "sourceCount": "3",
      "avgGBPerSourcePerDay": "25",
      "estGBPerDay": "75",
      "retentionDays": "90",
      "searchProfile": "medium",
      "notes": "Same Linux hosts can also send application logs. Keep those as separate rows for cleaner ownership and parsing."
    },
    {
      "id": "d05",
      "name": "Linux App Tier - Application Logs",
      "category": "application",
      "method": "file",
      "sourceHost": "app01, app02, app03",
      "hostGroup": "linux-app",
      "inputName": "payments-app",
      "sourceLocation": "/opt/payments/log/*.log",
      "collectionTier": "universal_forwarder",
      "targetIndex": "app",
      "sourcetype": "payments:log",
      "appName": "TA_payments_app",
      "sourceCount": "3",
      "avgGBPerSourcePerDay": "15",
      "estGBPerDay": "45",
      "retentionDays": "90",
      "searchProfile": "high",
      "notes": "Application logs from the same host group should be separate from OS logs so TA placement and validation stay precise."
    },
    {
      "id": "d06",
      "name": "Network Syslog",
      "category": "network",
      "method": "syslog",
      "sourceHost": "fw-core-01, fw-core-02",
      "hostGroup": "firewalls",
      "inputName": "syslog stream",
      "sourceLocation": "Firewalls / routers / switches",
      "collectionTier": "heavy_forwarder",
      "targetIndex": "netops",
      "sourcetype": "syslog",
      "appName": "SC4S_or_vendor_TA",
      "sourceCount": "2",
      "avgGBPerSourcePerDay": "110",
      "estGBPerDay": "220",
      "retentionDays": "180",
      "searchProfile": "medium",
      "notes": "Prefer SC4S or HF collection tier."
    },
    {
      "id": "d07",
      "name": "CrowdStrike API",
      "category": "security",
      "method": "api",
      "sourceHost": "falcon-api",
      "hostGroup": "saas-security",
      "inputName": "detections stream",
      "sourceLocation": "SaaS API",
      "collectionTier": "heavy_forwarder",
      "targetIndex": "security",
      "sourcetype": "crowdstrike:events",
      "appName": "vendor_TA",
      "sourceCount": "1",
      "avgGBPerSourcePerDay": "18",
      "estGBPerDay": "18",
      "retentionDays": "180",
      "searchProfile": "medium",
      "notes": "Use dedicated HF or modular input tier."
    },
    {
      "id": "d08",
      "name": "App JSON via HEC",
      "category": "application",
      "method": "hec",
      "sourceHost": "checkout-api, mobile-gateway",
      "hostGroup": "app-hec",
      "inputName": "hec-json",
      "sourceLocation": "App producers",
      "collectionTier": "heavy_forwarder",
      "targetIndex": "app",
      "sourcetype": "app:json",
      "appName": "custom_hec_app",
      "sourceCount": "2",
      "avgGBPerSourcePerDay": "30",
      "estGBPerDay": "60",
      "retentionDays": "60",
      "searchProfile": "high",
      "notes": "HEC receiver on HF or indexer tier."
    }
  ]
