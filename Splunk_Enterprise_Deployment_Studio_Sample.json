  "requirements": {
    "dailyIngestTB": "2.5",
    "retentionDays": "180",
    "searchConcurrency": "high",
    "availabilityTarget": "HA",
    "drTarget": "active-active capable",
    "dataResidency": "site-aware",
    "compliance": "TLS, RBAC, change control"
