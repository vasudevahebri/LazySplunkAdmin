    "peakConcurrentSearches": "18",
    "scheduledSearches": "60",
    "growthPct": "25",
    "safetyPct": "20",
    "compressionRatio": "0.5",
    "rawDataPct": "15",
    "tsidxPct": "35",
    "peakBurstMultiplier": "3",
    "networkHeadroomPct": "30",
