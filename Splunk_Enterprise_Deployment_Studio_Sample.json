    "summaryAccelPct": "10",
    "plannedLanMbps": "1000",
    "plannedWanMbps": "250",
    "plannedIndexerCores": "24",
    "plannedIndexerRamGB": "64",
    "plannedIndexerUsableTB": "6",
    "plannedIndexerIops": "4000",
    "plannedSearchHeadCores": "16",
    "plannedSearchHeadRamGB": "32",
    "plannedSearchHeadStorageGB": "300",
    "plannedHFCores": "12",
    "plannedHFRamGB": "12",
